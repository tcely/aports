7830b8a26e3b318d1cb58c56db79453e269cc7be6f7b396987305b49a331e0098b7f737c2f70ee8e3f481aa45f14dee9fc3d76d274d22ca526bcbf1a828209f7  gcc14-implicit-function-declaration.patch
