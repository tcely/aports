diff -rupN a/doc/manual/meson.build b/doc/manual/meson.build
--- a/doc/manual/meson.build	2026-01-07 14:14:23.000000000 +0000
+++ b/doc/manual/meson.build	2026-05-01 18:13:07.010000000 +0000
@@ -71,7 +71,7 @@ subdir('source')
 
 # Hacky way to figure out if `nix` is an `ExternalProgram` or
 # `Executable`. Only the latter can occur in custom target input lists.
-if nix.full_path().startswith(meson.build_root())
+if nix.full_path().startswith(meson.project_build_root())
   nix_input = nix
 else
   nix_input = []
