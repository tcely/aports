# Maintainer: Natanael Copa <ncopa@alpinelinux.org>
pkgname=libcdio-paranoia
pkgver=10.2.2.0.2_git20260227
pkgrel=0
_gitrev=307fa2e43dad116b5a9ffe36424fbfd08da30a8f
pkgdesc="CD paranoia on top of libcdio"
url="https://www.gnu.org/software/libcdio/"
arch="all"
license="GPL-2.0-or-later AND LGPL-2.0-or-later"
makedepends="libcdio-dev autoconf automake libtool"
subpackages="$pkgname-dev $pkgname-doc"
# Temporarily switch to github source, upstream test fix for libcdio 2.3.0
# compatibility includes .BIN test data not in the tarball
# source="https://ftp.gnu.org/gnu/libcdio/libcdio-paranoia-$_pkgver.tar.bz2
source="$pkgname-$pkgver.tar.gz::https://github.com/libcdio/libcdio-paranoia/archive/$_gitrev.tar.gz"
builddir="$srcdir/$pkgname-$_gitrev"

prepare() {
	default_prepare

	sed -i \
		-e "s/\$1+\$2/$pkgver/" \
		configure.ac
	autoreconf -i
}

build() {
	./configure \
		--build=$CBUILD \
		--host=$CHOST \
		--prefix=/usr \
		--sysconfdir=/etc \
		--mandir=/usr/share/man \
		--infodir=/usr/share/info \
		--localstatedir=/var \
		--disable-static
	make
}

check() {
	make check
}

package() {
	make DESTDIR="$pkgdir" install
}

sha512sums="
aba2562c365f3da1fe2610f4cc81a4800baa076fd8467e03979c407a222aeece186360020b49cef27ce57094be8b9eede90c27f27f33e2a703f90c759768ea85  libcdio-paranoia-10.2.2.0.2_git20260227.tar.gz
"
